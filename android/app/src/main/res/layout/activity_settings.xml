<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/settings"
            android:textColor="@color/button_text"
            android:textSize="22sp" />

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- CONNECTION                                                         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Connection" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <RadioGroup android:id="@+id/connection_group"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:orientation="vertical">
            <RadioButton android:id="@+id/radio_wifi_manual"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WiFi — manual IP" android:textColor="@color/button_text" android:checked="true"/>
            <RadioButton android:id="@+id/radio_wifi_auto"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WiFi — auto discover" android:textColor="@color/button_text"/>
            <RadioButton android:id="@+id/radio_hotspot"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Phone hotspot (no router)" android:textColor="@color/button_text"/>
            <RadioButton android:id="@+id/radio_bluetooth"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bluetooth" android:textColor="@color/button_text"/>
        </RadioGroup>

        <!-- Hotspot hint — shown only when hotspot mode selected -->
        <TextView android:id="@+id/hotspot_hint"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"
            android:layout_marginBottom="6dp" android:visibility="gone"
            android:text="1. Enable hotspot on this phone\n2. Connect your PC to that hotspot\n3. PC gets IP 192.168.43.x — server auto-found via discovery\n4. Start server normally (no special flags needed)"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <EditText android:id="@+id/ip_input"
                android:layout_width="170dp" android:layout_height="wrap_content"
                android:background="@color/button_default" android:hint="@string/enter_ip"
                android:inputType="text" android:padding="10dp"
                android:textColor="@color/button_text" android:textColorHint="#888888"/>
            <Button android:id="@+id/btn_discover"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp" android:background="@drawable/shoulder_button_bg"
                android:text="AUTO" android:textColor="@color/button_text"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp" android:text="@string/auto_connect"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/auto_discover_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Paired Bluetooth device" android:textColor="@color/button_text"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/bt_device_spinner"
            android:layout_width="240dp" android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@color/button_default" android:padding="10dp"/>
        <TextView android:id="@+id/bluetooth_hint"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"
            android:layout_marginBottom="20dp" android:visibility="gone"
            android:text="Pair your PC in phone Bluetooth settings first.\nServer must be running — Bluetooth is enabled by default.\nNote: BT has higher latency than WiFi."/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- APPEARANCE                                                         -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Appearance" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Controller theme" android:textColor="@color/button_text"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/theme_spinner"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/button_default" android:padding="10dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Accent color" android:textColor="@color/button_text"
                android:layout_marginEnd="12dp"/>
            <View android:id="@+id/accent_preview"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btn_pick_accent"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:background="@drawable/center_button_bg"
                android:text="Cycle" android:textColor="@color/button_text" android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <Button android:id="@+id/btn_pick_bg_image"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shoulder_button_bg"
                android:text="Pick image / video" android:textColor="@color/button_text" android:textSize="11sp"/>
            <Button android:id="@+id/btn_clear_bg_image"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:background="@drawable/center_button_bg"
                android:text="Clear" android:textColor="@color/button_text" android:textSize="11sp"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- OPACITY                                                            -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Opacity" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Master -->
        <TextView android:id="@+id/opacity_master_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Master: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_master_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="10dp" android:max="100" android:progress="100"/>

        <!-- Joysticks -->
        <TextView android:id="@+id/opacity_joysticks_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Joysticks: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_joysticks_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- D-Pad -->
        <TextView android:id="@+id/opacity_dpad_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="D-Pad: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_dpad_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- Face Buttons -->
        <TextView android:id="@+id/opacity_face_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Face Buttons: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_face_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- Triggers -->
        <TextView android:id="@+id/opacity_triggers_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Triggers: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_triggers_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- Shoulders -->
        <TextView android:id="@+id/opacity_shoulders_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Shoulders: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_shoulders_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- Center Buttons -->
        <TextView android:id="@+id/opacity_center_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Center Btns: 100%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_center_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="100" android:progress="100"/>

        <!-- Background -->
        <TextView android:id="@+id/opacity_bg_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Background: 85%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/opacity_bg_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" android:max="100" android:progress="85"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- GYROSCOPE                                                          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Gyroscope" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp" android:text="@string/gyro_enabled"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/gyro_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Gyro output" android:textColor="@color/button_text"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/gyro_mode_spinner"
            android:layout_width="220dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/button_default" android:padding="10dp"/>

        <TextView android:id="@+id/gyro_sensitivity_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sensitivity: 1.0" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/gyro_sensitivity_bar"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="30" android:progress="10"/>

        <TextView android:id="@+id/gyro_deadzone_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Deadzone: 0.05" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/gyro_deadzone_bar"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="30" android:progress="5"/>

        <Button android:id="@+id/btn_calibrate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/center_button_bg"
            android:text="Reset gyro (CAL in-app)" android:textColor="@color/button_text"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- OTHER (Haptic, Profile, Layout)                                    -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Other" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp" android:text="Haptic feedback"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/haptic_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <TextView android:id="@+id/haptic_strength_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Strength: 128" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/haptic_strength_bar"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" android:max="255" android:progress="128"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Controller profile" android:textColor="@color/button_text"
            android:layout_marginBottom="4dp"/>
        <Spinner android:id="@+id/profile_spinner"
            android:layout_width="200dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/button_default" android:padding="10dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp" android:text="Use Custom Layout"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/custom_layout_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button android:id="@+id/btn_edit_layout"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/center_button_bg"
            android:text="Edit Button Layout" android:textColor="@color/button_text"/>


        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- TOUCHPAD / MOUSE                                                   -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Touchpad / Mouse" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Show touchpad button in HUD"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/touchpad_toggle_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <TextView android:id="@+id/touchpad_sensitivity_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Mouse sensitivity: 1.8" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/touchpad_sensitivity_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="40" android:progress="18"/>

        <TextView android:id="@+id/touchpad_scroll_sensitivity_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Scroll sensitivity: 0.4" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/touchpad_scroll_sensitivity_bar"
            android:layout_width="260dp" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" android:max="30" android:progress="4"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Use PC screen stream as touchpad background"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/touchpad_screen_bg_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="false"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"
            android:layout_marginBottom="20dp"
            android:text="1-finger: move/tap/double-tap/long-press(drag-lock)\n2-finger tap=right-click  2-finger V=scroll  2-finger H=h-scroll\n2-finger pinch/spread=zoom  3-finger tap=middle-click\n3-finger swipe L/R=back/fwd  U/D=task-view/desktop"/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- MIC INPUT                                                           -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Microphone Input" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Enable mic streaming to PC"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/mic_stream_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="false"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Show mic toggle button in HUD"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/mic_toggle_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="false"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="11sp"
            android:layout_marginBottom="20dp"
            android:text="Streams phone mic to PC (TCP port 5009). Server must be started with --mic flag (done automatically by start_server.bat).\nHUD button lets you mute/unmute mid-session.\nInstall VB-Audio Virtual Cable on PC to route mic to apps."/>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- PC STREAMING                                                        -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PC Streaming" android:textColor="#00BFFF"
            android:textSize="16sp" android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Audio Stream -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PC Audio (port 5007)" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="4dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Stream audio from PC"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/audio_stream_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:id="@+id/audio_volume_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Volume: 80%" android:textColor="@color/button_text"/>
        <SeekBar android:id="@+id/audio_volume_bar"
            android:layout_width="220dp" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" android:max="100" android:progress="80"/>

        <!-- Screen Stream -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="PC Screen (port 5008)" android:textColor="#AAAAAA"
            android:textSize="12sp" android:layout_marginBottom="4dp"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Show PC screen as background"
                android:textColor="@color/button_text"/>
            <Switch android:id="@+id/screen_stream_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SAVE / CANCEL                                                       -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btn_save"
                android:layout_width="100dp" android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/shoulder_button_bg"
                android:text="@string/save" android:textColor="@color/button_text"/>
            <Button android:id="@+id/btn_cancel"
                android:layout_width="100dp" android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/shoulder_button_bg"
                android:text="@string/cancel" android:textColor="@color/button_text"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
